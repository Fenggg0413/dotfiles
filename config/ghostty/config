# ============================================
# Ghostty Terminal - Complete Configuration
# ============================================
# File: ~/.config/ghostty/config
# Reload: Cmd+Shift+, (macOS)
# View options: ghostty +show-config --default --docs

# --- Typography ---
font-family = "Maple Mono NF CN"
font-size = 18
font-thicken = false

# Powerline glyphs (U+E0A0-U+E0D7) — Maple's PUA glyphs leave hairline seams
# between segments in Ghostty. JetBrainsMono NF Mono draws them cell-perfect
# and matches the shape iTerm2 renders (which uses the same font).
font-codepoint-map = U+E0A0-U+E0D7=JetBrainsMono Nerd Font Mono

# Geometric Shapes (U+25A0-U+25FF) — defaults to emoji presentation under
# Unicode 9+; Ghostty would route ◼◻●○ etc. to Apple Color Emoji (bitmap →
# blurry). Pin them to a text font so they render as crisp filled shapes,
# matching iTerm2's behavior.
font-codepoint-map = U+25A0-U+25FF=JetBrainsMono Nerd Font Mono

# --- Theme and Colors ---
# Dracula — matches my iTerm2 palette
theme = Dracula

# --- Window and Appearance ---
background-opacity = 1
background-blur-radius = 0
macos-titlebar-style = transparent
window-padding-x = 2
window-padding-y = 2
# Split sub-cell remainder evenly top/bottom instead of dumping it at the bottom.
window-padding-balance = true
window-save-state = always
window-theme = auto

# --- Cursor ---
cursor-style = bar
cursor-style-blink = false
cursor-opacity = 0.8

# --- Mouse ---
mouse-hide-while-typing = true
copy-on-select = clipboard

# --- Quick Terminal (Quake-style dropdown) ---
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# --- Security ---
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# --- Shell Integration ---
shell-integration = detect

# --- Keybindings ---
# Tabs
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
keybind = cmd+w=close_surface

# Splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+down=goto_split:bottom

# Font size
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size

# Quick terminal global hotkey
keybind = global:alt+grave_accent=toggle_quick_terminal

# Splits management
keybind = cmd+shift+e=equalize_splits
keybind = cmd+shift+f=toggle_split_zoom

# Reload config
keybind = cmd+shift+comma=reload_config

# --- Performance ---
# Default 10MB — larger buffers slow scroll-region rerenders.
scrollback-limit = 10000000
